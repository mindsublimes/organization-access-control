<h1><%= @organization.name %></h1>
<p>Min Age: <%= @organization.min_age %></p>
<p>Max Age: <%= @organization.max_age %></p>
<p>Members: <%= @members.count %></p>
<%= link_to 'Edit', edit_organization_path(@organization) %> |
<%= link_to 'Analytics', analytics_organization_path(@organization) %> |
<%= link_to 'Back', organizations_path %>

<h2>Members</h2>
<ul>
  <% @members.each do |membership| %>
    <li><%= membership.user.email %> (<%= membership.role %>)</li>
  <% end %>
</ul>
<%= link_to 'Manage Memberships', organization_memberships_path(@organization) %>
